# Firebase Cloud Messaging
# Obtén estas claves en: Firebase Console → Configuración del proyecto → Cloud Messaging

# VAPID Key: Certificados web push → "Generar par de claves" → copiar la clave
VITE_VAPID_KEY=TU_VAPID_KEY_AQUI

# Server Key (clave de servidor): en la misma pestaña Cloud Messaging
VITE_FCM_SERVER_KEY=TU_SERVER_KEY_AQUI
